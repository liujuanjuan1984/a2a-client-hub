## Example environment variables for a2a-client-hub (backend)
## Copy this file to `backend/.env` and adjust values as needed.

# ===== Auth =====
# If true, the first registered user becomes a superuser.
FIRST_USER_SUPERUSER=1

# JWT (RS*/ES* only; RS256 recommended)
JWT_ALGORITHM=RS256
JWT_ISSUER=a2a-client-hub

# Access/Refresh TTL (seconds)
# - Access token: 15-60 minutes recommended
# - Refresh token: 7-30 days recommended
JWT_ACCESS_TOKEN_TTL_SECONDS=1800
JWT_REFRESH_TOKEN_TTL_SECONDS=1209600

# RS256 keys (PEM)
# Tip: you can store multi-line PEM as a single line using literal \\n.
# Keys must be valid PEM, and private/public values must be a matching pair.
JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"
JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\\n...\\n-----END PUBLIC KEY-----\\n"

# Note: symmetric algorithms (HS*) are not supported in this repository.
# JWT signing uses the PEM keys above.

# ===== App =====
APP_NAME=a2a-client-hub-backend
# Set to `production` to enable strict security baseline checks.
# Allowed values: development / staging / production
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO
# `text` is the default for local readability.
# Set to `json` when you want structured logs for collection pipelines.
LOG_FORMAT=text

# ===== Database =====
# Full example:
DATABASE_URL=postgresql://username:password@localhost:5432/a2a_client
# Local socket example (optional):
# DATABASE_URL=postgresql:///a2a_client
SCHEMA_NAME=a2a_client_hub_schema
DATABASE_ECHO=false

# Base64 URL-safe key for encrypting stored user-provided LLM / agent tokens.
# Required if you use bearer auth for stored credentials.
# Generate:
# python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
USER_LLM_TOKEN_ENCRYPTION_KEY=

# Base64 URL-safe key for encrypting admin-managed hub A2A credentials (Catalog).
# If left blank, the backend falls back to USER_LLM_TOKEN_ENCRYPTION_KEY.
HUB_A2A_TOKEN_ENCRYPTION_KEY=

# ===== API =====
API_V1_PREFIX=/api/v1

# ===== CORS =====
# Localhost defaults below are for development convenience only.
# In production APP_ENV=production, configure explicit non-local origins.
BACKEND_CORS_ORIGINS='["http://localhost:3000","http://127.0.0.1:3000","http://localhost:5173","http://127.0.0.1:5173"]'

# ===== WebSocket (invoke/ws) =====
# The WebSocket endpoint (`/api/v1/me/a2a/agents/{agent_id}/invoke/ws`) validates the `Origin` header.
#
# - If `WS_ALLOWED_ORIGINS` is empty, the backend falls back to `BACKEND_CORS_ORIGINS`.
# - For non-localhost deployments, be sure to include your frontend origin(s), e.g.
#   `["https://a2a-dev.example.com"]`.
# - In production APP_ENV=production, set this explicitly (non-empty, no localhost, no `*`).
WS_ALLOWED_ORIGINS='[]'
WS_REQUIRE_ORIGIN=true

# One-time WS ticket settings (used by `/me/a2a/agents/{agent_id}/invoke/ws-token`).
# IMPORTANT: This placeholder is for local development only.
# In production, set a strong secret (>=32 chars, random).
WS_TICKET_SECRET_KEY=change-me-32-chars-minimum-ws-ticket-secret
WS_TICKET_TTL_SECONDS=90
WS_TICKET_LENGTH=48

# ===== Refresh Cookie (HttpOnly) =====
# In production, use HTTPS and keep AUTH_REFRESH_COOKIE_SECURE=true.
AUTH_REFRESH_COOKIE_NAME=a2a_refresh_token
# For local dev over HTTP, you may temporarily set this to false.
# In production APP_ENV=production requires true.
AUTH_REFRESH_COOKIE_SECURE=true
AUTH_REFRESH_COOKIE_SAMESITE=lax
AUTH_REFRESH_COOKIE_PATH=/api/v1/auth

# ===== A2A =====
# A2A is a core capability of a2a-client-hub and is always enabled.
# You can still tune timeouts/limits via the A2A_* settings in `app.core.config.Settings`.
#
# Schedule execution safety controls:
# - Business execution timeout ceiling (seconds)
# A2A_SCHEDULE_TASK_INVOKE_TIMEOUT=7200
# - Heartbeat write interval while run is executing (seconds, minimum 15)
# A2A_SCHEDULE_RUN_HEARTBEAT_INTERVAL_SECONDS=30
# - Days to retain terminal schedule execution history before daily cleanup
# A2A_SCHEDULE_EXECUTION_RETENTION_DAYS=30

# Allowlisted hosts for outbound A2A HTTP requests (agent card + transports + extensions).
# APP_ENV=production requires this list to be non-empty and disallows literal `*`.
# Examples:
# A2A_PROXY_ALLOWED_HOSTS='["example.com","*.example.com","api.example.com:443"]'
A2A_PROXY_ALLOWED_HOSTS='[]'
