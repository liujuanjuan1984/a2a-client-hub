# Common Compass Backend Environment Variables Template
# Copy this file to .env and update the values according to your setup

# ===== 认证设置 =====
FIRST_USER_SUPERUSER=1      # 首个注册是否为超级管理员

# JWT 设置（推荐 RS256 非对称签名）
JWT_ALGORITHM=RS256
JWT_ISSUER=common-compass

# Access/Refresh TTL（秒）
# - Access token 建议 15-60 分钟
# - Refresh token 建议 7-30 天
JWT_ACCESS_TOKEN_TTL_SECONDS=1800
JWT_REFRESH_TOKEN_TTL_SECONDS=1209600

# RS256 密钥（PEM）。
# 说明：支持把 PEM 写成一行并用字面 \\n 表示换行。
JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"
JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\\n...\\n-----END PUBLIC KEY-----\\n"

# 若临时使用 HS256（不推荐），请设置：
# JWT_ALGORITHM=HS256
# JWT_SECRET_KEY=change-me-32-chars-minimum-secret-key

# Application Settings
APP_NAME=Common Compass API
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/dbname
SCHEMA_NAME=common_compass_schema
DATABASE_ECHO=false

# API Configuration
API_V1_PREFIX=/api/v1

# CORS Settings
BACKEND_CORS_ORIGINS='["http://localhost:3000","http://127.0.0.1:3000","http://localhost:5173","http://127.0.0.1:5173"]'

# Refresh Cookie（HttpOnly）
# 生产环境建议使用 HTTPS 并保持 AUTH_REFRESH_COOKIE_SECURE=true
AUTH_REFRESH_COOKIE_NAME=cc_refresh_token
# 本地开发（http）如需验证 refresh cookie，可临时设为 false；生产环境务必保持 true。
AUTH_REFRESH_COOKIE_SECURE=true
AUTH_REFRESH_COOKIE_SAMESITE=lax
AUTH_REFRESH_COOKIE_PATH=/api/v1/auth

# Cardbox Settings
CARD_BOX_DUCKDB_PATH=./storage/cardbox.duckdb

# 控制 Cardbox 在运行时要记录多少“血缘 / 变更历史”的开关，目前支持的档位主要有三种：
# - full
#    - 记录最完整的历史：
#        1. CardHistory 会保存每一次卡片生成、替换的关系（例如某张卡由哪些旧卡变换而来）。
#        2. CardBoxHistory 还会额外保存每次策略执行前后的 CardBox 快照和输入参数。
#    - 适合做深度调试、需要回放每一步策略执行结果的场景。
#    - 代价是额外的磁盘空间和写入成本。
# - card_only（我们后端默认值）
#    - 只启用 CardHistory，保留卡片级的血缘信息，但不再存储整个 CardBox 的快照。
#    - 既能看到“谁生成了谁”，又避免保存大块快照数据，适合作为生产环境的常规模式。
# - none
#    - 完全关闭历史记录：不会调用 CardHistory / CardBoxHistory，仅保留卡片本身。
#    - 最省资源、写入最快，但后续就无法追踪任何血缘信息或调试路径。

CARD_BOX_HISTORY_LEVEL=full
CARD_BOX_VERBOSE_LOGS=false

# ===== A2A 设置 =====
A2A_ENABLED=false
# 支持直接填写 JSON 字符串，或提供 JSON 文件路径。建议使用文件路径以便维护大体量配置。
# 例如：A2A_AGENTS=./config/a2a_agents.json
A2A_AGENTS=
