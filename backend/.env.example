## a2a-client-backend 环境变量示例
## 将本文件复制为 `backend/.env` 后按需调整。

# ===== 认证设置 =====
FIRST_USER_SUPERUSER=1      # 首个注册是否为超级管理员

# JWT 设置（推荐 RS256 非对称签名）
JWT_ALGORITHM=RS256
JWT_ISSUER=common-compass

# Access/Refresh TTL（秒）
# - Access token 建议 15-60 分钟
# - Refresh token 建议 7-30 天
JWT_ACCESS_TOKEN_TTL_SECONDS=1800
JWT_REFRESH_TOKEN_TTL_SECONDS=1209600

# RS256 密钥（PEM）。
# 说明：支持把 PEM 写成一行并用字面 \\n 表示换行。
JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"
JWT_PUBLIC_KEY_PEM="-----BEGIN PUBLIC KEY-----\\n...\\n-----END PUBLIC KEY-----\\n"

# 说明：本仓库不支持 HS256。请使用 RS256 并提供上述 PEM key。

# Application Settings
APP_NAME=a2a-client-backend
DEBUG=false
LOG_LEVEL=INFO

# Database Configuration
DATABASE_URL=postgresql://username:password@localhost:5432/dbname
SCHEMA_NAME=common_compass_schema
DATABASE_ECHO=false

# API Configuration
API_V1_PREFIX=/api/v1

# CORS Settings
BACKEND_CORS_ORIGINS='["http://localhost:3000","http://127.0.0.1:3000","http://localhost:5173","http://127.0.0.1:5173"]'

# Refresh Cookie（HttpOnly）
# 生产环境建议使用 HTTPS 并保持 AUTH_REFRESH_COOKIE_SECURE=true
AUTH_REFRESH_COOKIE_NAME=cc_refresh_token
# 本地开发（http）如需验证 refresh cookie，可临时设为 false；生产环境务必保持 true。
AUTH_REFRESH_COOKIE_SECURE=true
AUTH_REFRESH_COOKIE_SAMESITE=lax
AUTH_REFRESH_COOKIE_PATH=/api/v1/auth

# ===== A2A 设置 =====
A2A_ENABLED=false
# 支持直接填写 JSON 字符串，或提供 JSON 文件路径。建议使用文件路径以便维护大体量配置。
# 例如：A2A_AGENTS=./config/a2a_agents.json
A2A_AGENTS=
