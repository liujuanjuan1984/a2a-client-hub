{
  "name": "a2a-client-hub",
  "version": "1.5.0",
  "private": true,
  "description": "Frontend control-plane app for a2a-client-hub (Expo + React Native)",
  "keywords": [
    "a2a",
    "agent-to-agent",
    "ai-agents",
    "control-plane",
    "self-hosted"
  ],
  "license": "Apache-2.0",
  "author": "liujuanjuan1984",
  "repository": {
    "type": "git",
    "url": "https://github.com/liujuanjuan1984/a2a-client-hub.git",
    "directory": "frontend"
  },
  "bugs": {
    "url": "https://github.com/liujuanjuan1984/a2a-client-hub/issues"
  },
  "homepage": "https://github.com/liujuanjuan1984/a2a-client-hub#readme",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:clean": "expo start --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "publish:web": "bash scripts/publish-web.sh",
    "lint": "eslint app components hooks lib screens services store --ext .ts,.tsx --max-warnings=0",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "test": "jest",
    "check-types": "export NODE_OPTIONS=\"--max-old-space-size=1024\" && tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/react-query": "^5.56.2",
    "base-64": "^1.0.0",
    "expo": "~54.0.27",
    "expo-clipboard": "^8.0.8",
    "expo-constants": "~18.0.11",
    "expo-crypto": "^15.0.8",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.17",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "nativewind": "^4.0.37",
    "react": "19.1.2",
    "react-dom": "19.1.2",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-markdown-display": "^7.0.2",
    "react-native-mmkv": "^2.12.2",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-toast-message": "^2.3.3",
    "react-native-web": "^0.21.0",
    "zustand": "^4.5.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@testing-library/react-native": "^12.6.2",
    "@types/base-64": "^1.0.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^24.10.1",
    "@types/react": "~19.1.10",
    "@types/react-test-renderer": "^19.0.0",
    "babel-preset-expo": "^54.0.7",
    "eslint": "^9.39.2",
    "eslint-config-universe": "^15.0.3",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.14",
    "prettier": "^3.3.3",
    "react-test-renderer": "19.1.2",
    "tailwindcss": "^3.4.14",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "@xmldom/xmldom": "^0.8.12",
    "markdown-it": "^12.3.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "react",
        "react-dom"
      ]
    }
  }
}
