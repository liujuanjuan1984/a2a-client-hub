{
  "name": "a2a-client-hub",
  "version": "1.5.2",
  "private": true,
  "description": "Frontend control-plane app for a2a-client-hub (Expo + React Native)",
  "keywords": [
    "a2a",
    "agent-to-agent",
    "ai-agents",
    "control-plane",
    "self-hosted"
  ],
  "license": "Apache-2.0",
  "author": "liujuanjuan1984",
  "repository": {
    "type": "git",
    "url": "https://github.com/liujuanjuan1984/a2a-client-hub.git",
    "directory": "frontend"
  },
  "bugs": {
    "url": "https://github.com/liujuanjuan1984/a2a-client-hub/issues"
  },
  "homepage": "https://github.com/liujuanjuan1984/a2a-client-hub#readme",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:clean": "expo start --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "publish:web": "bash scripts/publish-web.sh",
    "lint": "eslint app components hooks lib screens services store --ext .ts,.tsx --max-warnings=0",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "test": "jest",
    "check-types": "export NODE_OPTIONS=\"--max-old-space-size=1024\" && tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "3.0.2",
    "@tanstack/react-query": "^5.97.0",
    "base-64": "^1.0.0",
    "expo": "~55.0.13",
    "expo-clipboard": "^55.0.13",
    "expo-constants": "~55.0.13",
    "expo-crypto": "^55.0.14",
    "expo-font": "~55.0.6",
    "expo-linking": "~55.0.12",
    "expo-router": "~55.0.11",
    "expo-secure-store": "~55.0.13",
    "expo-status-bar": "~55.0.5",
    "nativewind": "^4.2.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-native": "0.85.0",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-markdown-display": "^7.0.2",
    "react-native-mmkv": "^4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.24.0",
    "react-native-toast-message": "^2.3.3",
    "react-native-web": "^0.21.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@testing-library/react-native": "^13.3.3",
    "@types/base-64": "^1.0.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@types/react": "~19.2.14",
    "@types/react-test-renderer": "^19.0.0",
    "babel-preset-expo": "^55.0.16",
    "eslint": "^10.2.0",
    "eslint-config-universe": "^15.0.3",
    "jest": "^30.3.0",
    "jest-expo": "~55.0.15",
    "prettier": "^3.3.3",
    "react-test-renderer": "19.2.5",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2"
  },
  "overrides": {
    "@xmldom/xmldom": "^0.8.12",
    "markdown-it": "^12.3.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "react",
        "react-dom"
      ]
    }
  }
}
