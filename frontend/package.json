{
  "name": "a2a-universal-client",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "start:clean": "expo start --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "publish:web": "bash scripts/publish-web.sh",
    "lint": "eslint app components hooks lib screens services store --ext .ts,.tsx --max-warnings=0",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "test": "jest",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/react-query": "^5.56.2",
    "base-64": "^1.0.0",
    "expo": "~54.0.27",
    "expo-constants": "~18.0.11",
    "expo-crypto": "^15.0.8",
    "expo-router": "~6.0.17",
    "expo-secure-store": "~15.0.8",
    "expo-status-bar": "~3.0.9",
    "nativewind": "^4.0.37",
    "react": "19.1.2",
    "react-dom": "19.1.2",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-mmkv": "^2.12.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-toast-message": "^2.3.3",
    "react-native-web": "^0.21.0",
    "zustand": "^4.5.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@testing-library/react-native": "^12.6.2",
    "@types/base-64": "^1.0.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^24.10.1",
    "@types/react": "~19.1.10",
    "@types/react-test-renderer": "^19.0.0",
    "babel-preset-expo": "^54.0.7",
    "eslint": "^9.39.2",
    "eslint-config-universe": "^15.0.3",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.14",
    "prettier": "^3.3.3",
    "react-test-renderer": "19.1.2",
    "tailwindcss": "^3.4.14",
    "typescript": "~5.9.2"
  },
  "expo": {
    "install": {
      "exclude": [
        "react",
        "react-dom"
      ]
    }
  }
}
