{
  "expo": {
    "name": "A2AClientHub",
    "slug": "a2a-client-hub",
    "version": "1.5.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "scheme": "a2a-client-hub",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#05070a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.liujuanjuan.a2a.client",
      "buildNumber": "1",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#05070a"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.liujuanjuan.a2a.client",
      "predictiveBackGestureEnabled": true,
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "display": "standalone",
      "backgroundColor": "#05070a",
      "favicon": "./assets/pwa-icon.png",
      "splash": {
        "image": "./assets/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#05070a"
      }
    },
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ],
    "extra": {
      "router": {}
    },
    "owner": "liujuanjuan"
  }
}
